<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="resource-item" style="flex-grow: 1; flex-direction: row; height: 66px;">
        <ui:Label tabindex="-1" text="Label" parse-escape-sequences="true" display-tooltip-when-elided="true" name="ResourceName" style="flex-direction: row; width: 50%;" />
        <ui:Label tabindex="-1" text="Label" parse-escape-sequences="true" display-tooltip-when-elided="true" name="ResourceAmount" style="flex-direction: row; flex-basis: auto; width: 50%;" />
    </ui:VisualElement>
</ui:UXML>
